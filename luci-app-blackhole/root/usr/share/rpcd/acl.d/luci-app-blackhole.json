{
	"luci-app-blackhole": {
		"description": "Grant access to blackhole configuration",
		"read": {
			"uci": [ "blackhole" ],
			"file": [ 
				"/mnt/largedata/blackholeserver/blackhole.log",
				"/mnt/largedata/blackholeserver/mirrored/*",
				"/mnt/largedata/blackholeserver/content/*"
			],
			"ubus": {
				"rc": [ "init" ],
				"service": [ "list" ]
			}
		},
		"write": {
			"uci": [ "blackhole" ],
			"file": [ 
				"/mnt/largedata/blackholeserver/blackhole.log",
				"/mnt/largedata/blackholeserver/mirrored/*",
				"/mnt/largedata/blackholeserver/content/*"
			],
			"ubus": {
				"uci": [ "apply" ],
				"rc": [ "init" ],
				"service": [ "list" ]
			}
		}
	}
}
